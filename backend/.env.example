# =============================================================================
# Money Transfer Tracker – Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# ── Security ─────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_very_long_random_secret
JWT_EXPIRES_IN=7d

# ── Database (Google Cloud SQL PostgreSQL) ────────────────────────────────────
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
# Use 127.0.0.1 when connecting via Cloud SQL Proxy (recommended)
DATABASE_URL=postgresql://admin:PASSWORD@CLOUD_SQL_IP:5432/makomu_exchange

# Individual connection parameters (used if DATABASE_URL is not set)
DB_HOST=CLOUD_SQL_IP
DB_PORT=5432
DB_NAME=makomu_exchange
DB_USER=admin
DB_PASSWORD=PASSWORD
DB_SSL=true

# Connection pool settings
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=2000

# ── Google Cloud ──────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT_ID=your-project-id
CLOUD_SQL_INSTANCE=your-project-id:us-central1:money-transfer-db

# ── Twilio WhatsApp ───────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3001

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
